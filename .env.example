# ═══════════════════════════════════════════════════════════════
# ReelMagic — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ─── Auth (Clerk) ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/generate
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Database (Supabase) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Queue (Redis) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ─── Image Generation (fal.AI) ────────────────────────────────
FAL_KEY=your-fal-ai-key

# ─── Video Generation (Replicate — backup) ────────────────────
REPLICATE_API_TOKEN=r8_...

# ─── Video Generation (MiniMax/Kling — optional) ──────────────
MINIMAX_API_KEY=your-minimax-key
MINIMAX_BASE_URL=https://api.minimax.io

# ─── Voiceover (ElevenLabs) ───────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-key

# ─── Music (Suno — optional) ──────────────────────────────────
SUNO_API_KEY=your-suno-key

# ─── Storage (Cloudflare R2) ──────────────────────────────────
R2_ENDPOINT=https://account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=reelmagic-videos
R2_PUBLIC_URL=https://cdn.reelmagic.ai

# ─── Payments (Stripe) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Monitoring ───────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
